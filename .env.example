# GitHub Container Registry owner (GitHub username or org)
GHCR_OWNER=your-github-username

# Image tag to deploy (defaults to "latest")
IMAGE_TAG=latest

# Ollama (external LLM service — not included in compose)
NUXT_OLLAMA_URL=http://192.168.0.5:11434
NUXT_OLLAMA_MODEL=ministral-3b:8b
NUXT_OLLAMA_TEMPERATURE=0.15

# Paperless-ngx
NUXT_PAPERLESS_URL=https://your-paperless-instance
NUXT_PAPERLESS_TOKEN=your-api-token-here
NUXT_PUBLIC_PAPERLESS_BASE_URL=https://your-paperless-instance
