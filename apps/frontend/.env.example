# Redis (BullMQ backing store)
NUXT_REDIS_URL=redis://localhost:6379

# Docling PDF→Markdown conversion service
NUXT_DOCLING_URL=http://localhost:5001

# Ollama LLM
NUXT_OLLAMA_URL=http://localhost:11434
NUXT_OLLAMA_MODEL=ministral-3:8b
NUXT_OLLAMA_TEMPERATURE=0.15

# Paperless-ngx instance (server-side API access)
NUXT_PAPERLESS_URL=https://your-paperless-instance
NUXT_PAPERLESS_TOKEN=your-api-token-here

# Paperless-ngx base URL for document links in the UI (public)
NUXT_PUBLIC_PAPERLESS_BASE_URL=https://your-paperless-instance
