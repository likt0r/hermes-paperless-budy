# Docling conversion service (default: http://localhost:5001 when running via docker-compose)
DOCLING_URL=http://localhost:5001

# Ollama for metadata extraction (optional; if unset, pipeline still returns markdown + jobId)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_TEMPERATURE=0.15

# Paperless-ngx for reference data (optional; if unset, mock tags/document types are used)
PAPERLESS_URL=
PAPERLESS_TOKEN=
